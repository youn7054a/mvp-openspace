# Open Space MVP 환경 변수 (Environment Variables)
# 이 파일을 .env 로 복사해서 사용하세요 (Copy this file to .env)

# SQLite 데이터베이스 경로 (Database URL)
DATABASE_URL=sqlite:///./openspace.db

# Resend 이메일 API 키 (Email provider key)
# 비워두면 매직링크가 콘솔/로그로 출력됩니다 (empty -> magic link printed to console)
RESEND_API_KEY=

# 매직링크 생성에 쓰이는 외부 접속 주소 (Base URL for magic links)
BASE_URL=http://localhost:5001

# 관리자 페이지 비밀번호 (Admin area password)
ADMIN_PASSWORD=change-me

# 발신 이메일 주소 (Resend 사용 시, From address)
MAIL_FROM=Open Space <onboarding@resend.dev>

# 세션 쿠키 서명 키 (Session signing secret)
SESSION_SECRET=dev-insecure-session-secret-change-me

# 업로드 이미지 저장 디렉토리 (Uploaded image directory)
UPLOAD_DIR=./uploads
