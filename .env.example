# Open Space MVP 환경 변수 (Environment Variables)
# 이 파일을 .env 로 복사해서 사용하세요 (Copy this file to .env)

# SQLite 데이터베이스 경로 (Database URL)
DATABASE_URL=sqlite:///./openspace.db


# 외부 공개 주소 (Public base URL)
BASE_URL=http://localhost:5001

# 관리자 이메일 (Admin emails) — 이 이메일로 로그인하면 관리자. 쉼표로 여러 개
ADMIN_EMAILS=you@pycon.kr


# 세션 쿠키 서명 키 (Session signing secret)
SESSION_SECRET=dev-insecure-session-secret-change-me

# 업로드 이미지 저장 디렉토리 (Uploaded image directory)
UPLOAD_DIR=./uploads

# 개발용 수기 로그인 허용 (Dev login bypass)
# localhost 에선 PyCon 쿠키(Domain=pycon.kr)가 서버로 오지 않아 신원 검증이 안 됩니다.
# 1 로 켜면 홈의 '개발 로그인' 폼 / POST /dev/login 으로 이메일 신원을 흉내낼 수 있습니다.
# 운영(pycon.kr 서브도메인)에선 반드시 비워두세요(서버가 PyCon 세션을 직접 검증).
DEV_LOGIN_ENABLED=1
